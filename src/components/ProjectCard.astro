---
import type { Project } from "@/data/projects";
import { withBase } from "@/utils/path";

type Props = {
  project: Project;
  compact?: boolean;
};

const { project, compact = false } = Astro.props;
const slides =
  project.images ??
  (project.image ? [{ src: project.image, alt: project.imageAlt ?? project.title }] : []);
const hasSwiper = Boolean(project.images && project.images.length > 1);
---

<article class={compact ? "project-card compact" : "project-card"}>
  <div class={hasSwiper ? "project-swiper" : "project-media"} aria-label={`${project.title} images`}>
    <div class="project-swiper-track">
      {
        slides.map((image) => (
          <img src={withBase(image.src)} alt={image.alt} loading="lazy" />
        ))
      }
    </div>
    {
      hasSwiper && (
        <>
          <button class="project-swiper-button previous" type="button" aria-label="Previous image" data-direction="previous">
            ‹
          </button>
          <button class="project-swiper-button next" type="button" aria-label="Next image" data-direction="next">
            ›
          </button>
        </>
      )
    }
    {
      hasSwiper && (
        <div class="project-swiper-dots" aria-hidden="true">
          {slides.map(() => <span />)}
        </div>
      )
    }
  </div>
  {
    hasSwiper && (
      <dialog class="project-image-modal" aria-label={`${project.title} image preview`}>
        <button class="project-modal-close" type="button" aria-label="Close preview">
          ×
        </button>
        <button class="project-modal-button previous" type="button" aria-label="Previous preview image" data-direction="previous">
          ‹
        </button>
        <img src={withBase(slides[0].src)} alt={slides[0].alt} loading="lazy" />
        <button class="project-modal-button next" type="button" aria-label="Next preview image" data-direction="next">
          ›
        </button>
      </dialog>
    )
  }
  <div class="project-body">
    <div class="project-meta">
      <span>{project.type}</span>
      <span>{project.period}</span>
    </div>
    <h3>{project.title}</h3>
    <p>{project.summary}</p>
    {project.role && <p class="project-role">{project.role}</p>}
    <ul class="project-highlights">
      {project.highlights.map((item) => <li>{item}</li>)}
    </ul>
    {
      !compact && project.story && (
        <dl class="project-story">
          <div>
            <dt>我想練什麼</dt>
            <dd>{project.story.goal}</dd>
          </div>
          <div>
            <dt>我怎麼設計</dt>
            <dd>{project.story.design}</dd>
          </div>
          <div>
            <dt>我遇到什麼問題</dt>
            <dd>{project.story.challenge}</dd>
          </div>
          <div>
            <dt>我學到什麼</dt>
            <dd>{project.story.learned}</dd>
          </div>
        </dl>
      )
    }
    <div class="tag-list" aria-label={`${project.title} tags`}>
      {project.areas.map((area) => <span>{area}</span>)}
      {project.tags.map((tag) => <span>{tag}</span>)}
    </div>
    {
      project.links && project.links.length > 0 && (
        <div class="link-row">
          {project.links.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">
              {link.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>

<script>
  document.querySelectorAll(".project-swiper").forEach((swiper) => {
    const track = swiper.querySelector(".project-swiper-track");
    const buttons = swiper.querySelectorAll(".project-swiper-button");
    const modal = swiper.parentElement?.querySelector(".project-image-modal");
    const modalImage = modal?.querySelector("img");
    const closeButton = modal?.querySelector(".project-modal-close");
    const modalButtons = modal?.querySelectorAll(".project-modal-button") ?? [];
    const images = Array.from(swiper.querySelectorAll(".project-swiper-track img"));
    let activeIndex = 0;

    if (!(track instanceof HTMLElement)) return;

    const updateModalImage = (index: number) => {
      if (!(modalImage instanceof HTMLImageElement)) return;

      activeIndex = (index + images.length) % images.length;
      const image = images[activeIndex];

      if (!(image instanceof HTMLImageElement)) return;

      modalImage.src = image.src;
      modalImage.alt = image.alt;
    };

    buttons.forEach((button) => {
      button.addEventListener("click", (event) => {
        event.stopPropagation();
        const direction = button.getAttribute("data-direction") === "previous" ? -1 : 1;
        track.scrollBy({
          left: direction * track.clientWidth,
          behavior: "smooth",
        });
      });
    });

    swiper.addEventListener("click", (event) => {
      if ((event.target as Element).closest(".project-swiper-button")) return;
      if (!(modal instanceof HTMLDialogElement) || !(modalImage instanceof HTMLImageElement)) return;

      const clickedImage = (event.target as Element).closest("img");
      const currentIndex = Math.round(track.scrollLeft / track.clientWidth);
      const clickedIndex = clickedImage instanceof HTMLImageElement ? images.indexOf(clickedImage) : currentIndex;

      updateModalImage(clickedIndex >= 0 ? clickedIndex : currentIndex);
      modal.showModal();
    });

    modalButtons.forEach((button) => {
      button.addEventListener("click", (event) => {
        event.stopPropagation();
        const direction = button.getAttribute("data-direction") === "previous" ? -1 : 1;
        updateModalImage(activeIndex + direction);
      });
    });

    closeButton?.addEventListener("click", () => {
      if (modal instanceof HTMLDialogElement) {
        modal.close();
      }
    });

    modal?.addEventListener("click", (event) => {
      if (event.target === modal && modal instanceof HTMLDialogElement) {
        modal.close();
      }
    });
  });
</script>
