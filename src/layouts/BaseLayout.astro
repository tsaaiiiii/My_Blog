---
import "../styles/global.css";
import { profile } from "@/data/profile";
import { withBase, withoutBase } from "@/utils/path";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = `${profile.englishName} | ${profile.role}`,
  description = `${profile.englishName} | ${profile.role}`,
} = Astro.props;

const navItems = [
  { href: "/", label: "首頁" },
  { href: "/notes", label: "筆記" },
  { href: "/projects", label: "專案" },
];

const currentPath = withoutBase(Astro.url.pathname);
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="google" content="notranslate" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <title>{title}</title>
  </head>
<body class={currentPath === "/" ? "home-page" : ""}>
    <header class="site-header">
      <a class="brand" href={withBase("/")} aria-label="Go to home">
        <span>{profile.englishName}</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        {
          navItems.map((item) => (
            <a href={withBase(item.href)} class={currentPath === item.href ? "active" : ""}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>© 2026 Windy Tsai</span>
      <span class="footer-meta">
        <span>Personal notes and projects.</span>
      </span>
    </footer>
  </body>
</html>
