---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { noteCategories } from "@/data/profile";
import { withBase } from "@/utils/path";

export function getStaticPaths() {
  return noteCategories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const notes = (await getCollection("notes"))
  .filter((note) => note.data.category === category.slug && !note.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const categoryPath = `/notes/${category.slug}`;
---

<BaseLayout title={`${category.title} 筆記 | Windy Tsai`} description={category.description}>
  <section class="page-heading">
    <a class="back-link" href={withBase("/notes")}>回筆記分類</a>
    <p class="section-kicker">Notes / {category.slug}</p>
    <h1>{category.title}</h1>
    <p>{category.description}</p>
    <div class="tag-list">
      <a href={withBase(categoryPath)} data-note-all>All</a>
      {
        category.tags.map((tag) => (
          <a href={`${withBase(categoryPath)}?tag=${encodeURIComponent(tag)}`} data-note-tag={tag}>
            {tag}
          </a>
        ))
      }
    </div>
  </section>

  <section class="note-filters" aria-label="Note category filters">
    <a href={withBase("/notes")}>全部</a>
    {
      noteCategories.map((item) => (
        <a class={item.slug === category.slug ? "active" : ""} href={withBase(`/notes/${item.slug}`)}>
          {item.title}
        </a>
      ))
    }
  </section>

  {
    notes.length > 0 ? (
      <section class="note-list">
        {notes.map((note) => (
          <article class="note-item" data-note-tags={JSON.stringify(note.data.tags)}>
            <time datetime={note.data.date.toISOString()}>{note.data.date.toLocaleDateString("zh-TW")}</time>
            <h2>{note.data.title}</h2>
            {note.data.description && <p>{note.data.description}</p>}
            <div class="tag-list">
              {note.data.tags.map((tag) => (
                <a href={`${withBase(categoryPath)}?tag=${encodeURIComponent(tag)}`} data-note-tag={tag}>
                  {tag}
                </a>
              ))}
            </div>
          </article>
        ))}
      </section>
      <section class="empty-state note-filter-empty" hidden>
        <h2>還在躺，請等等</h2>
      </section>
    ) : (
      <section class="empty-state">
        <h2>還在躺，請等等</h2>
      </section>
    )
  }
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const selectedTags = new Set(params.getAll("tag"));
  const allButtons = document.querySelectorAll("[data-note-all]");
  const tagLinks = document.querySelectorAll("[data-note-tag]");
  const noteItems = document.querySelectorAll("[data-note-tags]");
  const filterEmpty = document.querySelector(".note-filter-empty");

  const updateTagLinks = () => {
    allButtons.forEach((button) => {
      button.classList.toggle("active", selectedTags.size === 0);
    });

    tagLinks.forEach((link) => {
      const tag = link.getAttribute("data-note-tag");
      link.classList.toggle("active", Boolean(tag && selectedTags.has(tag)));
    });
  };

  const updateNotes = () => {
    let visibleCount = 0;

    noteItems.forEach((item) => {
      const tags = JSON.parse(item.getAttribute("data-note-tags") ?? "[]");
      const shouldShow = [...selectedTags].every((tag) => tags.includes(tag));
      item.toggleAttribute("hidden", !shouldShow);
      if (shouldShow) visibleCount += 1;
    });

    filterEmpty?.toggleAttribute("hidden", visibleCount > 0);
  };

  const updateUrl = () => {
    const nextParams = new URLSearchParams();
    selectedTags.forEach((selectedTag) => nextParams.append("tag", selectedTag));
    const query = nextParams.toString();
    window.history.replaceState({}, "", query ? `?${query}` : window.location.pathname);
  };

  allButtons.forEach((button) => {
    button.addEventListener("click", (event) => {
      event.preventDefault();
      selectedTags.clear();
      updateUrl();
      updateTagLinks();
      updateNotes();
    });
  });

  tagLinks.forEach((link) => {
    link.addEventListener("click", (event) => {
      event.preventDefault();
      const tag = link.getAttribute("data-note-tag");
      if (!tag) return;

      if (selectedTags.has(tag)) {
        selectedTags.delete(tag);
      } else {
        selectedTags.add(tag);
      }

      updateUrl();
      updateTagLinks();
      updateNotes();
    });
  });

  updateTagLinks();
  updateNotes();
</script>
