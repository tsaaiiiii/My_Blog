---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { noteCategories } from "@/data/profile";
import { withBase } from "@/utils/path";

export function getStaticPaths() {
  return noteCategories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const notes = (await getCollection("notes"))
  .filter((note) => note.data.category === category.slug && !note.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const categoryPath = `/notes/${category.slug}`;
const getNoteSlug = (id: string) => id.split("/").pop()?.replace(/\.md$/, "") ?? id;
const getNotePath = (note: (typeof notes)[number]) => `${categoryPath}/${getNoteSlug(note.id)}`;
---

<BaseLayout title={`${category.title} 筆記 | Windy Tsai`} description={category.description}>
  <section class="page-heading">
    <p class="section-kicker">Notes / {category.slug}</p>
    <h1>{category.title}</h1>
  </section>

  <section class="note-filters" aria-label="Note category filters">
    <a href={withBase("/notes")}>全部</a>
    {
      noteCategories.map((item) => (
        <a class={item.slug === category.slug ? "active" : ""} href={withBase(`/notes/${item.slug}`)}>
          {item.title}
        </a>
      ))
    }
  </section>

  {
    notes.length > 0 ? (
      <section class="note-list">
        {notes.map((note) => (
          <article class="note-item">
            <div class="note-item-top">
              <time datetime={note.data.date.toISOString()}>{note.data.date.toLocaleDateString("zh-TW")}</time>
              <a href={withBase(`/notes/${note.data.category}`)}>{note.data.category}</a>
            </div>
            <h2>
              <a class="note-title-link" href={withBase(getNotePath(note))}>{note.data.title}</a>
            </h2>
            {note.data.description && <p>{note.data.description}</p>}
            {note.data.tags.length > 0 && (
              <div class="note-hashtags" aria-label={`${note.data.title} tags`}>
                {note.data.tags.map((tag) => <span>#{tag}</span>)}
              </div>
            )}
          </article>
        ))}
      </section>
    ) : (
      <section class="empty-state">
        <h2>還在躺，請等等</h2>
      </section>
    )
  }
</BaseLayout>
