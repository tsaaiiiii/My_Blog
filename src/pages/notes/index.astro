---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { noteCategories } from "@/data/profile";
import { getCollection } from "astro:content";
import { withBase } from "@/utils/path";

const notes = (await getCollection("notes"))
  .filter((note) => !note.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const getNoteSlug = (id: string) => id.split("/").pop()?.replace(/\.md$/, "") ?? id;
const getNotePath = (note: (typeof notes)[number]) => `/notes/${note.data.category}/${getNoteSlug(note.id)}`;
---

<BaseLayout title="筆記 | Windy Tsai" description="以主題為核心整理 Frontend、TypeScript、Backend、Workflow 與 Interview 筆記。">
  <section class="page-heading">
    <p class="section-kicker">Notes</p>
    <h1>筆記</h1>
  </section>

  <section class="note-filters" aria-label="Note category filters">
    <a class="active" href={withBase("/notes")}>全部</a>
    {
      noteCategories.map((category) => (
        <a href={withBase(`/notes/${category.slug}`)}>
          {category.title}
        </a>
      ))
    }
  </section>

  {
    notes.length > 0 ? (
      <section class="note-list">
        {notes.map((note) => (
          <article class="note-item">
            <div class="note-item-top">
              <time datetime={note.data.date.toISOString()}>
                {note.data.date.toLocaleDateString("zh-TW")}
              </time>
              <a href={withBase(`/notes/${note.data.category}`)}>{note.data.category}</a>
            </div>
            <h2>
              <a class="note-title-link" href={withBase(getNotePath(note))}>{note.data.title}</a>
            </h2>
            {note.data.description && <p>{note.data.description}</p>}
            {note.data.tags.length > 0 && (
              <div class="note-hashtags" aria-label={`${note.data.title} tags`}>
                {note.data.tags.map((tag) => <span>#{tag}</span>)}
              </div>
            )}
          </article>
        ))}
      </section>
    ) : (
      <section class="empty-state">
        <h2>還在躺，請等等</h2>
      </section>
    )
  }
</BaseLayout>
